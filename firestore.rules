rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasUserUid() {
      return signedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /repairs/{docId} {
      allow create: if hasUserUid();
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /maintenance/{docId} {
      allow create: if hasUserUid();
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /expenses/{docId} {
      allow create: if hasUserUid();
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /profiles/{uid} {
      allow create, update: if isOwner(uid) && request.resource.data.uid == request.auth.uid;
      allow read, delete: if isOwner(uid) && resource.data.uid == request.auth.uid;
    }
  }
}